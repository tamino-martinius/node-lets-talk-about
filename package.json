{
  "name": "lets-talk-about",
  "version": "0.5.3",
  "description": "Easily create slides from Markdown. Customize your slides with HTML and CSS. Host your slides for free on GitHub Pages.",
  "type": "module",
  "bin": {
    "lets-talk-about": "bin/cli.js"
  },
  "exports": {
    ".": "./src/plugin.js",
    "./compiler": "./src/compiler.js",
    "./client/slides": "./src/client/slides.js",
    "./client/sync": "./src/client/sync.js",
    "./client/styles.css": "./src/client/styles.css",
    "./client/presenter.css": "./src/client/presenter.css"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "author": "Tamino Martinius",
  "license": "MIT",
  "homepage": "https://github.com/tamino-martinius/lets-talk-about",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamino-martinius/lets-talk-about.git"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "slides",
    "presentation",
    "markdown",
    "vite"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "gh-pages": "^6.3.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.15.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3"
  }
}
